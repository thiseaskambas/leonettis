# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=leonettis

# Admin authentication
ADMIN_PASSWORD=change_me
ADMIN_JWT_SECRET=replace_with_a_random_32_plus_char_secret
OPENAI_API_KEY=your_openai_api_key

# Sevalla S3-compatible storage
SEVALLA_ENDPOINT=https://your-sevalla-endpoint
SEVALLA_BUCKET=leonettis
SEVALLA_ACCESS_KEY=your_sevalla_access_key
SEVALLA_SECRET_KEY=your_sevalla_secret_key
SEVALLA_PUBLIC_URL=https://your-public-bucket-url

# Contact form email
RESEND_API_KEY=your_resend_api_key
CONTACT_EMAIL_TO=you@example.com

# Optional media base URL (used by media helpers)
NEXT_PUBLIC_MEDIA_BASE_URL=https://blogfeed-ar0uj.sevalla.storage/
